rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자 이메일
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "rute20002@gmail.com";
    }

    // 차단된 사용자 차단
    function isBanned() {
      return request.auth != null
        && exists(/databases/$(database)/documents/banned_users/$(request.auth.uid));
    }

    // ---- Ideas ----
    match /ideas/{ideaId} {
      allow read: if true;

      allow create: if isAdmin() || (
        request.auth != null
        && !isBanned()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 5000
        && request.resource.data.waitlistCount == 0
        && request.resource.data.paidWaitlistCount == 0
        && request.resource.data.freeWaitlistCount == 0
        && request.resource.data.likeCount == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.status == "waiting"
        && (!('imageDataList' in request.resource.data)
            || (request.resource.data.imageDataList is list
                && request.resource.data.imageDataList.size() <= 5))
      );

      allow update: if isAdmin()
        || (
          request.auth != null
          && !isBanned()
          && (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['waitlistCount','paidWaitlistCount','freeWaitlistCount','likeCount','commentCount'])
            ||
            ( resource.data.authorUid == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
              && request.resource.data.status in ['waiting','ready','building','completed','cancelled']
            )
          )
        );

      allow delete: if isAdmin();

      match /waitlist/{userId} {
        allow read: if true;
        allow create: if (isAdmin() || (request.auth != null && !isBanned() && request.auth.uid == userId))
          && request.resource.data.tier in ['free','paid'];
        allow update: if isAdmin()
          || (request.auth != null && !isBanned() && request.auth.uid == userId
              && request.resource.data.tier in ['free','paid']);
        allow delete: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      }

      match /likes/{userId} {
        allow read: if true;
        allow create: if isAdmin() || (
          request.auth != null && !isBanned()
          && request.auth.uid == userId
          && request.resource.data.uid == userId
        );
        allow delete: if isAdmin() || (request.auth != null && request.auth.uid == userId);
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if true;

        // 일반 사용자: 자기 자신만 작성. 관리자: 임의 authorUid 허용 (AI 댓글)
        allow create: if isAdmin() || (
          request.auth != null && !isBanned()
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
        );

        allow delete: if isAdmin()
          || (request.auth != null && resource.data.authorUid == request.auth.uid);

        allow update: if isAdmin();
      }
    }

    // ---- Subscribers ----
    match /subscribers/{email} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == email);
      allow create, update: if request.auth != null
        && request.auth.token.email == email
        && request.resource.data.email == email;
      allow delete: if isAdmin() || (request.auth != null && request.auth.token.email == email);
    }

    // ---- Mail ----
    match /mail/{mailId} {
      allow read: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.to is string
        && request.resource.data.to == request.auth.token.email;
      allow update, delete: if isAdmin();
    }

    // ---- 차단 사용자 ----
    match /banned_users/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ---- 관리자 설정 ----
    match /settings/{docId} {
      allow read: if true; // 자동 큐 처리 시 클라이언트가 읽어야 함
      allow write: if isAdmin();
    }

    // ---- 스케줄 댓글 큐 ----
    match /scheduled_comments/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ---- 분석 이벤트 ----
    match /events/{id} {
      // 누구나 자기 방문 기록 추가 가능 (검증 최소화)
      allow create: if request.resource.data.type is string
        && request.resource.data.type.size() <= 50;
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
