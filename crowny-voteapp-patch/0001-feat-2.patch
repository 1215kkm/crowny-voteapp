+  margin: 0 0 14px;
+  border-radius: var(--radius-sm);
+  overflow: hidden;
+  background: #f1f5f9;
+}
+.idea-image {
+  width: 100%;
+  height: auto;
+  display: block;
+}
+
+/* 샘플(예시) 배지 */
+.badge-sample {
+  display: inline-block;
+  padding: 2px 8px;
+  background: #e0e7ff;
+  color: #4338ca;
+  font-size: 0.7rem;
+  font-weight: 700;
+  border-radius: var(--radius-full);
+  vertical-align: middle;
