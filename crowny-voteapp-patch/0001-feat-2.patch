+}
+.image-preview-info {
+  font-size: 0.78rem;
+  color: var(--color-text-light);
+}
+.image-remove-btn {
+  background: transparent;
+  color: var(--color-danger);
+  border: 1px solid var(--color-danger);
+  border-radius: var(--radius-full);
+  padding: 4px 12px;
+  font-size: 0.78rem;
+  font-weight: 600;
